generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

  url = env("DATABASE_URL")
}

model User {
  id                     String        @id @default(cuid())
  nome                   String
  email                  String        @unique
  password               String
  role                   Role          @default(CLIENT)
  image                  String        @default("/default.png")
  telefone               String?
  createdAt              DateTime      @default(now())
  services               Service[]     @relation("ProfessionalServices")
  bookingsAsClient       Agendamento[] @relation("ClientBookings")
  bookingsAsProfessional Agendamento[] @relation("ProfessionalBookings")

  images    Images[]
  bookMarks BookMark[]

  receivedNotifications Notification[] @relation("UserNotifications") // Recebeu notificações
  sentNotifications     Notification[] @relation("NotificationSender") // Enviou notificações
  comments              Comments[]
}

model Service {
  id             String   @id @default(cuid())
  nome           String
  description    String?
  duration       Int
  price          Float
  professionalId String?
  professional   User?    @relation("ProfessionalServices", fields: [professionalId], references: [id])
  createdAt      DateTime @default(now())

  bookings      Agendamento[]
  images        Images[]
  bookMarks     BookMark[]
  notifications Notification[]
  comments      Comments[]
}

model Agendamento {
  id             String            @id @default(cuid())
  date           DateTime
  endDate        DateTime
  status         AgendamentoStatus @default(PENDING)
  clientId       String
  serviceId      String
  professionalId String
  createdAt      DateTime          @default(now())

  client       User    @relation("ClientBookings", fields: [clientId], references: [id])
  service      Service @relation(fields: [serviceId], references: [id])
  professional User    @relation("ProfessionalBookings", fields: [professionalId], references: [id])

  @@map("Booking")
}

model Images {
  id        String   @id @default(cuid())
  userId    String?
  url       String   @default("/default.png")
  createdAt DateTime @default(now())
  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])
}

model Comments {
  id          String   @id @default(cuid())
  userId      String
  serviceId   String
  commentText String
  createdAt   DateTime @default(now())
  url         String?  @default("/default.png")
  service     Service? @relation(fields: [serviceId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])
}

model BookMark {
  id        String @id @default(cuid())
  userId    String
  serviceId String

  service Service? @relation(fields: [serviceId], references: [id])
  user    User?    @relation(fields: [userId], references: [id])
}

model Notification {
  id        String  @id @default(uuid())
  recevidId String // Quem recebe
  senderId  String? // Quem gerou
  serviceId String?
  message   String

  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user    User     @relation("UserNotifications", fields: [recevidId], references: [id], onDelete: Cascade)
  sender  User?    @relation("NotificationSender", fields: [senderId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  userId String?

  @@index([recevidId])
  @@index([senderId])
}

enum Role {
  ADMIN
  PROFESSIONAL
  CLIENT
}

enum AgendamentoStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}
